{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "MAVEN",
    "maven": {
      "goal": "spring-boot:build",
      "cmd": "mvn clean package -DskipTests"
    }
  },
  "deploy": {
    "numInstances": 1,
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 10,
    "healthCheckPath": "/api/auth/me",
    "waiter": "none"
  }
}
