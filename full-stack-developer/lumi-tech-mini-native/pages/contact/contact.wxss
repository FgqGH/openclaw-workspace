/* 咨询页面样式 - 现代化设计 */
.contact {
  background-color: #F8FAFC;
  min-height: 100vh;
  width: 100%;
  box-sizing: border-box;
}

/* 顶部区域 */
.hero {
  padding: 70rpx 40rpx 90rpx;
  background: linear-gradient(135deg, #EC4899 0%, #DB2777 50%, #BE185D 100%);
  position: relative;
  overflow: hidden;
}

.hero::before {
  content: '';
  position: absolute;
  top: -35%;
  right: -20%;
  width: 450rpx;
  height: 450rpx;
  background: rgba(255, 255, 255, 0.1);
  border-radius: 50%;
}

.hero::after {
  content: '';
  position: absolute;
  bottom: -25%;
  left: -15%;
  width: 300rpx;
  height: 300rpx;
  background: rgba(255, 255, 255, 0.08);
  border-radius: 50%;
}

.title {
  font-size: 52rpx;
  font-weight: 800;
  color: #FFFFFF;
  display: block;
  margin-bottom: 16rpx;
  letter-spacing: 1rpx;
  text-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.15);
  position: relative;
  z-index: 1;
}

.subtitle {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.9);
  display: block;
  line-height: 1.7;
  position: relative;
  z-index: 1;
}

/* 内容区域 */
.content {
  padding: 50rpx 32rpx 100rpx;
  width: 100%;
  box-sizing: border-box;
  margin-top: -30rpx;
  position: relative;
  z-index: 10;
}

/* 表单样式 */
.form {
  background: #FFFFFF;
  padding: 40rpx;
  border-radius: 28rpx;
  box-shadow: 0 12rpx 40rpx rgba(236, 72, 153, 0.15);
  margin-bottom: 40rpx;
  width: 100%;
  box-sizing: border-box;
}

.form-group {
  margin-bottom: 32rpx;
  width: 100%;
  box-sizing: border-box;
}

.label {
  font-size: 28rpx;
  font-weight: 600;
  color: #1E293B;
  display: block;
  margin-bottom: 14rpx;
}

.input {
  width: 100%;
  height: 96rpx;
  padding: 0 28rpx;
  border: 2rpx solid #E2E8F0;
  border-radius: 20rpx;
  font-size: 30rpx;
  color: #1E293B;
  background-color: #F8FAFC;
  box-sizing: border-box;
  margin: 0;
  line-height: 96rpx;
  transition: all 0.3s ease;
}

.input:focus {
  border-color: #EC4899;
  background-color: #FFFFFF;
  box-shadow: 0 0 0 4rpx rgba(236, 72, 153, 0.1);
}

.input::placeholder {
  color: #94A3B8;
}

.textarea {
  width: 100%;
  padding: 28rpx;
  border: 2rpx solid #E2E8F0;
  border-radius: 20rpx;
  font-size: 30rpx;
  color: #1E293B;
  background-color: #F8FAFC;
  box-sizing: border-box;
  min-height: 220rpx;
  margin: 0;
  line-height: 1.6;
}

.textarea:focus {
  border-color: #EC4899;
  background-color: #FFFFFF;
}

.textarea::placeholder {
  color: #94A3B8;
}

/* 提交按钮 */
.btn {
  width: 100%;
  padding: 32rpx 0;
  background: linear-gradient(135deg, #EC4899 0%, #DB2777 100%);
  color: #FFFFFF;
  border-radius: 100rpx;
  font-size: 34rpx;
  font-weight: 700;
  text-align: center;
  margin-top: 24rpx;
  box-shadow: 0 12rpx 40rpx rgba(236, 72, 153, 0.35);
  box-sizing: border-box;
  letter-spacing: 2rpx;
}

.btn-disabled {
  background: linear-gradient(135deg, #CBD5E1 0%, #94A3B8 100%);
  box-shadow: none;
}

/* 提示消息 */
.success-msg {
  display: block;
  text-align: center;
  margin-top: 28rpx;
  padding: 20rpx;
  background: linear-gradient(135deg, #ECFDF5 0%, #D1FAE5 100%);
  border-radius: 16rpx;
  font-size: 28rpx;
  color: #059669;
  font-weight: 500;
}

.error-msg {
  display: block;
  text-align: center;
  margin-top: 28rpx;
  padding: 20rpx;
  background: linear-gradient(135deg, #FEF2F2 0%, #FECACA 100%);
  border-radius: 16rpx;
  font-size: 28rpx;
  color: #DC2626;
  font-weight: 500;
}

/* 联系信息卡片 */
.info-card {
  background: linear-gradient(135deg, #FFFFFF 0%, #FDF2F8 100%);
  padding: 40rpx;
  border-radius: 28rpx;
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.06);
  border: 2rpx solid #FCE7F3;
}

.info-title {
  font-size: 34rpx;
  font-weight: 700;
  color: #1E293B;
  display: block;
  margin-bottom: 32rpx;
  text-align: center;
}

.info-item {
  display: flex;
  align-items: center;
  gap: 20rpx;
  padding: 24rpx;
  background: #FFFFFF;
  border-radius: 18rpx;
  margin-bottom: 16rpx;
}

.info-item:last-child {
  margin-bottom: 0;
}

.info-icon {
  font-size: 40rpx;
  width: 72rpx;
  height: 72rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(135deg, #FCE7F3 0%, #FBCFE8 100%);
  border-radius: 18rpx;
  flex-shrink: 0;
}

.info-text {
  font-size: 30rpx;
  color: #1E293B;
  font-weight: 500;
}