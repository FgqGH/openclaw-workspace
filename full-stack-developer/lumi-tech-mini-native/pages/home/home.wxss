/* 首页样式 - 现代化设计 */
.home {
  background-color: #F8FAFC;
  min-height: 100vh;
}

/* 顶部英雄区域 */
.hero {
  padding: 80rpx 40rpx 100rpx;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 50%, #f093fb 100%);
  position: relative;
  overflow: hidden;
}

.hero-bg {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  z-index: 0;
}

.hero .container {
  position: relative;
  z-index: 1;
}

.title {
  font-size: 56rpx;
  font-weight: 800;
  color: #FFFFFF;
  display: block;
  margin-bottom: 20rpx;
  letter-spacing: 1rpx;
  line-height: 1.3;
  text-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.15);
}

.subtitle {
  font-size: 30rpx;
  color: rgba(255, 255, 255, 0.9);
  display: block;
  line-height: 1.7;
  max-width: 90%;
}

/* 数据统计区域 */
.stats {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 24rpx;
  padding: 40rpx 32rpx;
  background: #FFFFFF;
  margin: -50rpx 32rpx 0;
  border-radius: 28rpx;
  box-shadow: 0 20rpx 60rpx rgba(102, 126, 234, 0.2), 0 4rpx 16rpx rgba(0, 0, 0, 0.05);
  position: relative;
  z-index: 10;
}

.stat-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 28rpx 20rpx;
  background: linear-gradient(145deg, #f8fafc 0%, #eef2f7 100%);
  border-radius: 20rpx;
  transition: all 0.3s ease;
}

.stat-value {
  font-size: 52rpx;
  font-weight: 800;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  letter-spacing: -1rpx;
}

.stat-label {
  font-size: 24rpx;
  color: #64748B;
  margin-top: 10rpx;
  text-align: center;
  font-weight: 500;
}

/* 服务区域 */
.section {
  padding: 60rpx 32rpx 50rpx;
}

.section-title {
  font-size: 40rpx;
  font-weight: 700;
  color: #1E293B;
  margin-bottom: 36rpx;
  display: block;
  letter-spacing: 0.5rpx;
  position: relative;
  padding-left: 24rpx;
}

.section-title::before {
  content: '';
  position: absolute;
  left: 0;
  top: 50%;
  transform: translateY(-50%);
  width: 8rpx;
  height: 40rpx;
  background: linear-gradient(180deg, #667eea 0%, #764ba2 100%);
  border-radius: 4rpx;
}

.service-card {
  display: flex;
  gap: 28rpx;
  padding: 36rpx;
  background: #FFFFFF;
  border-radius: 24rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.04);
  border: 2rpx solid #F1F5F9;
  transition: all 0.3s ease;
}

.service-icon {
  width: 100rpx;
  height: 100rpx;
  border-radius: 24rpx;
  flex-shrink: 0;
}

.service-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: center;
}

.service-title {
  font-size: 34rpx;
  font-weight: 700;
  color: #1E293B;
  display: block;
  margin-bottom: 12rpx;
}

.service-sub {
  font-size: 26rpx;
  color: #64748B;
  line-height: 1.6;
}

/* 行动召唤区域 */
.cta {
  padding: 80rpx 40rpx 120rpx;
  background: linear-gradient(180deg, #F8FAFC 0%, #EEF2FF 100%);
  text-align: center;
  position: relative;
}

.cta::before {
  content: '';
  position: absolute;
  top: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 200rpx;
  height: 4rpx;
  background: linear-gradient(90deg, transparent, #667eea, transparent);
}

.cta-title {
  font-size: 36rpx;
  font-weight: 700;
  color: #1E293B;
  display: block;
  margin-bottom: 40rpx;
  line-height: 1.6;
}

.btn {
  display: inline-block;
  padding: 32rpx 80rpx;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: #FFFFFF;
  border-radius: 100rpx;
  font-size: 34rpx;
  font-weight: 700;
  box-shadow: 0 12rpx 40rpx rgba(102, 126, 234, 0.4);
  letter-spacing: 2rpx;
}
