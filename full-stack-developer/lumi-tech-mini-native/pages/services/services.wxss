/* 服务页面样式 - 现代化设计 */
.services {
  background-color: #F8FAFC;
  min-height: 100vh;
}

/* 顶部区域 */
.hero {
  padding: 70rpx 40rpx 90rpx;
  background: linear-gradient(135deg, #0EA5E9 0%, #6366F1 50%, #8B5CF6 100%);
  position: relative;
  overflow: hidden;
}

.hero::before {
  content: '';
  position: absolute;
  top: -40%;
  right: -20%;
  width: 500rpx;
  height: 500rpx;
  background: rgba(255, 255, 255, 0.1);
  border-radius: 50%;
}

.hero .container {
  position: relative;
  z-index: 1;
}

.title {
  font-size: 52rpx;
  font-weight: 800;
  color: #FFFFFF;
  display: block;
  margin-bottom: 16rpx;
  letter-spacing: 1rpx;
  text-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.15);
}

.subtitle {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.9);
  display: block;
  line-height: 1.7;
}

/* 内容区域 */
.content {
  padding: 50rpx 32rpx 100rpx;
  margin-top: -30rpx;
  position: relative;
  z-index: 10;
}

/* 服务卡片 */
.service-card {
  display: flex;
  gap: 28rpx;
  padding: 40rpx;
  background: #FFFFFF;
  border-radius: 28rpx;
  margin-bottom: 32rpx;
  box-shadow: 0 8rpx 32rpx rgba(99, 102, 241, 0.1);
  border: none;
  position: relative;
  overflow: hidden;
}

.service-card::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  width: 8rpx;
  height: 100%;
  background: linear-gradient(180deg, #0EA5E9 0%, #8B5CF6 100%);
}

.service-icon {
  width: 110rpx;
  height: 110rpx;
  border-radius: 28rpx;
  flex-shrink: 0;
}

.service-body {
  flex: 1;
  padding-left: 8rpx;
}

.service-title {
  font-size: 36rpx;
  font-weight: 700;
  color: #1E293B;
  display: block;
  margin-bottom: 14rpx;
}

.service-sub {
  font-size: 26rpx;
  color: #64748B;
  line-height: 1.7;
  display: block;
  margin-bottom: 28rpx;
}

/* 特性标签 */
.features {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.feature {
  padding: 14rpx 24rpx;
  background: linear-gradient(135deg, #EEF2FF 0%, #F0F9FF 100%);
  border-radius: 100rpx;
  font-size: 24rpx;
  color: #6366F1;
  font-weight: 500;
  border: 2rpx solid #E0E7FF;
}
